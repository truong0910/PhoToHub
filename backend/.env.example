# Supabase Project Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key

# Backend Application Configuration
PORT=3000

# SePay Automated Bank Transfer Gateway Configurations
PAYMENT_PROVIDER=sepay
SEPAY_ENV=production
SEPAY_MERCHANT_ID=your_sepay_merchant_id
SEPAY_SECRET_KEY=your_sepay_secret_key
SEPAY_IPN_URL=your_ngrok_or_public_https_endpoint_url
SEPAY_SUCCESS_URL=your_frontend_success_redirect_url
SEPAY_ERROR_URL=your_frontend_error_redirect_url
SEPAY_CANCEL_URL=your_frontend_cancel_redirect_url

# Supabase SMTP Email Service Configurations
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_SENDER="PhotoHub Studio <your_email@gmail.com>"
DISABLE_EMAIL=false

# Supabase Twilio SMS Service Configurations
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
